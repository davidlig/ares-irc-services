<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                           https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Domain\OperServ\Entity\OperRole" table="oper_roles">
        <unique-constraints>
            <unique-constraint name="uniq_role_name" columns="name"/>
        </unique-constraints>
        <id name="id" type="integer" column="id">
            <generator strategy="IDENTITY"/>
        </id>
        <field name="name" type="string" length="32" column="name"/>
        <field name="description" type="string" length="255" column="description"/>
        <field name="protected" type="boolean" column="protected"/>
        <many-to-many field="permissions" target-entity="App\Domain\OperServ\Entity\OperPermission">
            <join-table name="oper_role_permissions">
                <join-columns>
                    <join-column name="role_id" referenced-column-name="id"/>
                </join-columns>
                <inverse-join-columns>
                    <join-column name="permission_id" referenced-column-name="id"/>
                </inverse-join-columns>
            </join-table>
        </many-to-many>
    </entity>
</doctrine-mapping>