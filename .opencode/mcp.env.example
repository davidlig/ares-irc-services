# Copy this file to .opencode/mcp.env and fill in local values.
# .opencode/mcp.env is ignored by Git and must not be committed.

# IRC MCP connection.
# .opencode/plugins/irc-mcp-autostart.ts starts mcp-irc through a wrapper that
# watches the opencode process PID and kills the IRC process group on exit.
# .opencode/opencode.json connects to it as a remote MCP on localhost.
OPENCODE_IRC_URL=irc.example.net
OPENCODE_IRC_PORT=6697
OPENCODE_IRC_MCP_PORT=3005
OPENCODE_IRC_MCP_READY_TIMEOUT_MS=30000
OPENCODE_IRC_NICK=AresMCP
OPENCODE_IRC_HISTORY_LIMIT=1000

# Optional root identity for live MCP validation.
# Use only when a test requires root/IRCop/founder privileges.
# Keep the real password only in .opencode/mcp.env.
OPENCODE_IRC_ROOT_NICK=Ares
OPENCODE_IRC_ROOT_IDENTIFY_PASSWORD=change-me
OPENCODE_IRC_TEST_NICK_PREFIX=NickTest
OPENCODE_IRC_TEST_CHANNEL_PREFIX=#test-

# MariaDB MCP connection.
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_USER=ares_services
MARIADB_PASS=change-me
MARIADB_DB=ares_services

# Keep the MariaDB MCP read-only by default.
MARIADB_ALLOW_INSERT=false
MARIADB_ALLOW_UPDATE=false
MARIADB_ALLOW_DELETE=false
MARIADB_TIMEOUT_MS=10000
MARIADB_ROW_LIMIT=1000
