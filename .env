# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# Copy this file to .env.local and fill in your real values there.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=changeme
# Required by symfony/router to generate absolute URLs. Not used by the IRC
# services at runtime, but must be defined to silence framework warnings.
DEFAULT_URI=http://localhost
###< symfony/framework-bundle ###

###> ares/irc-link ###
# Fully-qualified domain name that Ares will present to the IRC daemon.
# Must match the server name configured in your IRCD link block.
IRC_SERVER_NAME=ares-services.davidlig.net

# Hostname or IP address of the IRC daemon to connect to.
IRC_IRCD_HOST=127.0.0.1

# Port of the IRC daemon's server-link listener.
IRC_IRCD_PORT=7000

# Shared link password defined in the IRCD link block.
IRC_LINK_PASSWORD=pass

# Human-readable description shown in /MAP and /LINKS.
IRC_DESCRIPTION="Ares IRC Services"

# S2S protocol driver: 'unreal' (UnrealIRCd) or 'inspircd' (InspIRCd).
IRC_PROTOCOL=unreal

# Set to 'true' to wrap the link in TLS/SSL.
IRC_USE_TLS=false

# Server ID (SID) for this services server. Format depends on IRC_PROTOCOL:
# - unreal: 3-digit numeric (e.g. 001, 002). See https://www.unrealircd.org/docs/Server_protocol:Server_ID
# - inspircd: 3-character alphanumeric (e.g. A0A, 0A0). Must be unique on the network.
IRC_SERVER_SID=002
###< ares/irc-link ###

###> ares/services ###
# Hostname advertised by service pseudo-clients (must match a ulines entry in the IRCD)
IRC_SERVICES_HOST=services.davidlig.net

# Default language for service messages (en | es)
SERVICES_DEFAULT_LANGUAGE=es

# Default timezone for date display in services (e.g. INFO). PHP timezone identifier (e.g. UTC, Europe/Madrid).
SERVICES_DEFAULT_TIMEZONE=UTC

# SQLite database path for service data (users, channels, memos, etc.)
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data/ares.db"

# NickServ pseudo-client settings
NICKSERV_NICK=NickServ
NICKSERV_IDENT=NickServ
NICKSERV_REALNAME="Nickname Registration Services"
# NickServ pseudo-client UID = <IRC_SERVER_SID> + suffix (must be unique on the network)
NICKSERV_UID=002AAAAAA

# Prefix for guest nicks when a user does not identify for a registered nick
NICKSERV_GUEST_PREFIX=Guest-

# Suffix appended to all custom vhosts (e.g. virtual → user part shows as userpart.virtual). Empty = no suffix.
NICKSERV_VHOST_SUFFIX=virtual

# Minimum seconds between RESEND requests per nick (default: 600 = 10 minutes)
NICKSERV_RESEND_MIN_INTERVAL=600

# Minimum seconds between REGISTER attempts per host/IP (default: 600 = 10 minutes; anti-bot)
NICKSERV_REGISTER_MIN_INTERVAL=600

# Maintenance: interval in seconds between maintenance cycles (default: 1 hour)
MAINTENANCE_INTERVAL=3600

# NickServ: days of inactivity after which a registered nick is dropped (0 = disabled)
NICKSERV_INACTIVITY_EXPIRY_DAYS=0

# Mailer — used for verification and email-change tokens (REGISTER, RESEND, SET EMAIL)
# Examples: smtp://user:pass@smtp.example.com:587 | sendmail://default | null://null (discard)
MAILER_DSN=null://null
# Sender address for outgoing emails (e.g. nickserv@yourserver.net)
MAILER_FROM="NickServ <nickserv@localhost>"
# Delay in seconds after each email send (0 = none; use 5+ to avoid provider blocks)
MAILER_SEND_DELAY_SECONDS=5
###< ares/services ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
# SQLite: no extra PHP extensions. For PostgreSQL install php-pgsql.
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data/ares.db"
# DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###
